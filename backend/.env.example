# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AutoShine Backend Config
# Copy this file and rename to .env (for local dev)
# On Render, add these same names under "Environment" — never upload .env itself
# NEVER share or commit .env to GitHub
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Server Port (Render sets this automatically, but keep a default)
PORT=5000

# MongoDB Connection String
# Get this from mongodb.com/atlas (free M0 cluster)
# Click Connect -> Drivers -> Copy connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/autoshine

# JWT Secret Key — generate your OWN, never reuse this example:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_random_64+_char_string_you_generate_yourself

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ADMIN ACCOUNTS — password is stored as a bcrypt HASH, never plain text.
# Generate a hash for your chosen password with:
#   node -e "console.log(require('bcryptjs').hashSync('yourPassword', 10))"
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_your_own_bcrypt_hash

# Optional 2nd admin account (e.g. for a friend/partner) — leave blank if unused
ADMIN_USERNAME_2=
ADMIN_PASSWORD_HASH_2=

# Email Configuration (Gmail)
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Business WhatsApp Number (with country code, no spaces)
WHATSAPP_NUMBER=923001234567

# Frontend URL — your LIVE Netlify URL (used for CORS whitelist)
FRONTEND_URL=https://superb-sopapillas-328181.netlify.app
